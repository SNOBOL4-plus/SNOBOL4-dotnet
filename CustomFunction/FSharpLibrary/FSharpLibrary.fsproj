<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>FSharpLibrary</AssemblyName>
    <Nullable>enable</Nullable>
    <EnableDefaultNamespaceProvider>false</EnableDefaultNamespaceProvider>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="FSharpLibrary.fs" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\Snobol4.Common\Snobol4.Common.csproj">
      <Private>True</Private>
    </ProjectReference>
  </ItemGroup>
</Project>
