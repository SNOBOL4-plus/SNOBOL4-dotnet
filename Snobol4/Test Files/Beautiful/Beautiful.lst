0049 0015 IsSnobol4End
0050 0016 *//----------- -------------------------------------------------------------------- -----------------
0051 0017                DEFINE('IsType(it,types)type')                                       :(IsTypeEnd)
0052 0018 IsType         types          POS(0) SPAN(&UCASE &LCASE) . type (',' | RPOS(0)) =   :F(FRETURN)
0053 0019                (IDENT(upr(type), 'NULL') IDENT(it))                                 :S(RETURN)
