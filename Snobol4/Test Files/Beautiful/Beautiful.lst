0175 0002 *// $Workfile: counter.inc $ $Revision: 3 $ $Date: 3/10/05 11:43a $ 
0176 0003 *//--------------------------------------------------------------------------------------------------
0177 0004 *//
0178 0005 *// A stack of counters. To be used with conditional assignment within pattern matching.
0179 0006 *// These routines are useful for counting items on the stack at multiple nesting levels which
0180 0007 *// are suitable for reduction on the stack.
0181 0008 *// Global: $'#N' -- link_counter()
0182 0009 *//
0183 0010 *//---------- --------------------------------------------------------------------- -----------------
0184 0011               DEFINE('InitCounter()')
0185 0012               DEFINE('PushCounter()')
0186 0013               DEFINE('IncCounter()')
0187 0014               DEFINE('DecCounter()')
0188 0015               DEFINE('TopCounter()')
0189 0016               DEFINE('PopCounter()')
0190 0017               DATA('link_counter(next,value)')                                      :(CounterEnd)
0191 0018 InitCounter   $'#N'          =                                                      :(RETURN)
0192 0019 PushCounter   OUTPUT         =    GT(xTrace, 4) 'PushCounter()'
0193 0020               $'#N'          =    link_counter($'#N', 0)
0194 0021               PushCounter    =    .dummy                                            :(NRETURN)
0195 0022 IncCounter    value($'#N')   =    value($'#N') + 1
0196 0023               OUTPUT         =    GT(xTrace, 4) value($'#N') ' = IncCounter()'     
0197 0024               IncCounter     =    .dummy                                            :(NRETURN)
0198 0025 DecCounter    value($'#N')   =    value($'#N') - 1
0199 0026               OUTPUT         =    GT(xTrace, 4) value($'#N') ' = DecCounter()'     
0200 0027               DecCounter     =    .dummy                                            :(NRETURN)
0201 0028 PopCounter    OUTPUT         =    GT(xTrace, 4) 'PopCounter()'
0202 0029               $'#N'          =    DIFFER($'#N') next($'#N')                         :F(FRETURN)
0203 0030               PopCounter     =    .dummy                                            :(NRETURN)
0204 0031 TopCounter    TopCounter     =    DIFFER($'#N') value($'#N')                        :F(FRETURN)
0205 0032               OUTPUT         =    GT(xTrace, 4) TopCounter ' = TopCounter()'        :(RETURN)
0206 0033 CounterEnd
0207 0034 *//--------------------------------------------------------------------------------------------------
0208 0035 *//
0209 0036 *// A stack of XML or HTML begin and end tags. To be used with unconditional assignment within
0210 0037 *// pattern matching.
0211 0038 *// Global: $'@B' -- link_tag()
0212 0039 *//         $'@E' -- link_tag()
0213 0040 *//
0214 0041 *//-------- --------------- --- ------------------------------------------- -------------------------
0215 0042             DATA('link_tag(next,value)')                                    
0216 0043 *//-------- --------------- --- ------------------------------------------- -------------------------
0217 0044             DEFINE('InitBegTag()')
0218 0045             DEFINE('PushBegTag(t)')
0219 0046             DEFINE('PopBegTag()')
0220 0047             DEFINE('TopBegTag()')
0221 0048             DEFINE('DumpBegTag()b,list,v')                                  :(BegTagEnd)
0222 0049 InitBegTag  $'@B'           =                                               :(RETURN)
0223 0050 PushBegTag  OUTPUT          =   GT(xTrace, 4) 'PushBegTag(' upr(t) ')'
0224 0051             $'@B'           =   link_tag($'@B', upr(t))
0225 0052             PushBegTag      =   IDENT(t)  .value($'@B')                     :S(NRETURN)
0226 0053             PushBegTag      =   DIFFER(t) .dummy                            :(NRETURN)
0227 0054 PopBegTag   OUTPUT          =   GT(xTrace, 4) (DIFFER($'@B') value($'@B'), 'FAIL') ' = PopBegTag()'
0228 0055             $'@B'           =   DIFFER($'@B') next($'@B')                   :F(FRETURN)
0229 0056             PopBegTag       =   .dummy                                      :(NRETURN)
0230 0057 TopBegTag   TopBegTag       =   DIFFER($'@B') value($'@B')                  :F(FRETURN)
0231 0058             OUTPUT          =   GT(xTrace, 4) TopBegTag ' = TopBegTag()'    :(RETURN)
0232 0059 DumpBegTag  DumpBegTag      =   .dummy                                      
0233 0060             GT(xTrace, 5)                                                   :F(NRETURN)
0234 0061             b               =   $'@B'
0235 0062 DumpBegTag3 v               =   DIFFER(b) value(b)                          :F(DumpBegTag9)
0236 0063             list            =   list (DIFFER(list) ', ', '') v
0237 0064             b               =   next(b)                                     :(DumpBegTag3)
0238 0065 DumpBegTag9 OUTPUT          =   '@B = (' list ')'                           :(NRETURN)
0239 0066 BegTagEnd
0240 0067 *//-------- --------------- --- ------------------------------------------- -------------------------
0241 0068             DEFINE('InitEndTag()')
0242 0069             DEFINE('PushEndTag(t)')
0243 0070             DEFINE('PopEndTag()')
0244 0071             DEFINE('TopEndTag()')
0245 0072             DEFINE('DumpEndTag()e,list,v')                                  :(EndTagEnd)
0246 0073 InitEndTag  $'@E'           =                                               :(RETURN)
0247 0074 PushEndTag  OUTPUT          =   GT(xTrace, 4) 'PushEndTag(' upr(t) ')'
0248 0075             $'@E'           =   link_tag($'@E', upr(t))
0249 0076             PushEndTag      =   IDENT(t)  .value($'@E')                     :S(NRETURN)
0250 0077             PushEndTag      =   DIFFER(t) .dummy                            :(NRETURN)
0251 0078 PopEndTag   OUTPUT          =   GT(xTrace, 4) (DIFFER($'@E') value($'@E'), 'FAIL') ' = PopEndTag()'
0252 0079             $'@E'           =   DIFFER($'@E') next($'@E')                   :F(FRETURN)
0253 0080             PopEndTag       =   .dummy                                      :(NRETURN)
0254 0081 TopEndTag   TopEndTag       =   DIFFER($'@E') value($'@E')                  :F(FRETURN)
0255 0082             OUTPUT          =   GT(xTrace, 4) TopEndTag ' = TopEndTag()'    :(RETURN)
0256 0083 DumpEndTag  DumpEndTag      =   .dummy
0257 0084             GT(xTrace, 5)                                                   :F(NRETURN)
0258 0085             e               =   $'@E'
0259 0086 DumpEndTag3 v               =   DIFFER(e) value(e)                          :F(DumpEndTag9)
0260 0087             list            =   list (DIFFER(list) ', ', '') v
0261 0088             e               =   next(e)                                     :(DumpEndTag3)
0262 0089 DumpEndTag9 OUTPUT          =   '@E = (' list ')'                           :(NRETURN)
0263 0090 EndTagEnd
