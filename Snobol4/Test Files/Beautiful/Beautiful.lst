1202 0424 *//-------------- -------------- -- ----------------------------------------------- ------------------------
1203 0425 ss_snoExprList    ss             =  ss(c[1], len)                                   :F(FRETURN)
1204 0426                   i              =  1
1205 0427 ss_snoExprList0   i              =  LT(i, n) i + 1                                  :F(RETURN)
