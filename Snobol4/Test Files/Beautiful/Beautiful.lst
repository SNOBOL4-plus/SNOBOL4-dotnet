1133 0355 *//============== ============== == =============================================== ========================
1134 0356 *//               Stringize Subject
1135 0357 *//               string = ss(x=tree, len=integer)
1136 0358 *//               Recursive function given a tree, to return SNOBOL4 code as a string.
1137 0359 *//
1138 0360                   DEFINE('ss(x,len)c,c1,c2,i,n,s,t,v')                              :(ssEnd)
1139 0361 ss                DIFFER(x)                                                         :F(RETURN)
1140 0362                   len            =  IDENT(len) 1024
1141 0363                   GT(len, 0)                                                        :F(FRETURN)
1142 0364                   t              =  t(x)
1143 0365                   v              =  v(x)
1144 0366                   n              =  n(x)
1145 0367                   c              =  c(x)
1146 0368                   OUTPUT         =  GT(doDebug, 0) 'ss(' t ')' ', sz = ' level '+' SIZE(v) ', v = ' v
1147 0369                   DIFFER(t)                                                         :S($('ss_' t))F(RETURN)
1148 0370 *//-------------- -------------- -- ----------------------------------------------- ------------------------
1149 0371 ss_snoBuiltinVar  ss             =  upr(v)                                          :(ss_atomic)
1150 0372 ss_snoFunction    ss             =  upr(v)                                          :(ss_atomic)
1151 0373 ss_snoId          ss             =  v                                               :(ss_atomic)
1152 0374 ss_snoInteger     ss             =  v                                               :(ss_atomic)
1153 0375 ss_snoLabel       v              POS(0) *snoSpecialNm RPOS(0)                       :S(ss_snoLabel0)F(ss_snoLabel1)
1154 0376 ss_snoLabel0      ss             =  upr(v)                                          :(ss_atomic)
1155 0377 ss_snoLabel1      ss             =  v                                               :(ss_atomic)
1156 0378 ss_snoProtKwd     ss             =  upr(v)                                          :(ss_atomic)
1157 0379 ss_snoReal        ss             =  v                                               :(ss_atomic)
1158 0380 ss_snoSpecialNm   ss             =  upr(v)                                          :(ss_atomic)
1159 0381 ss_snoString      ss             =  v                                               :(ss_atomic)
1160 0382 ss_snoUnprotKwd   ss             =  upr(v)                                          :(ss_atomic)
1161 0383 ss_atomic         LE(SIZE(ss), len)                                                 :S(RETURN)F(FRETURN)
1162 0384 *//-------------- -------------- -- ----------------------------------------------- ------------------------
1163 0385 ss_:()            ss             =  '(' ss(c[1], len - 2) ')'                       :S(RETURN)F(error)
1164 0386 ss_:<>            ss             =  '<' ss(c[1], len - 2) '>'                       :S(RETURN)F(error)
1165 0387 ss_:S()           ss             =  'S(' ss(c[1], len - 3) ')'                      :S(RETURN)F(error)
1166 0388 ss_:S<>           ss             =  'S<' ss(c[1], len - 3) '>'                      :S(RETURN)F(error)
1167 0389 ss_:F()           ss             =  'F(' ss(c[1], len - 3) ')'                      :S(RETURN)F(error)
1168 0390 ss_:F<>           ss             =  'F<' ss(c[1], len - 3) '>'                      :S(RETURN)F(error)
1169 0391 *//-------------- -------------- -- ----------------------------------------------- ------------------------
1170 0392 ssUnOp            ss             =  t ss(c[1], len - SIZE(t))                       :S(RETURN)F(FRETURN)
1171 0393 ssBinOp           ss             =  ss(c[1], len)                                   :F(FRETURN)
1172 0394                   ss             =  ss
1172 0394 +                                   ' '
1172 0394 +                                   t
1172 0394 +                                   ' '
1172 0394 +                                   ss(c[2], len - SIZE(ss) - SIZE(t) - 2)          :S(RETURN)F(FRETURN)
1173 0395 *//-------------- -------------- -- ----------------------------------------------- ------------------------
1174 0396 ss_!              EQ(n, 1)                                                          :S(ssUnOp)
1175 0397 ss_#              EQ(n, 1)                                                          :S(ssUnOp)
1176 0398                   EQ(n, 2)                                                          :S(ssBinOp)F(error)
1177 0399 ss_$              EQ(n, 1)                                                          :S(ssUnOp)
1178 0400                   EQ(n, 2)                                                          :S(ssBinOp)F(error)
