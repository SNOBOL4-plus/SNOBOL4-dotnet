1211 0433                   ss             =  ss ', ' ss(c[i], len - SIZE(ss) - 3)            :S($'ss_,0')F(FRETURN)
1212 0434 ss_,1             ss             =  ss ')'                                          :(RETURN)
1213 0435 *//-------------- -------------- -- ----------------------------------------------- ------------------------
1214 0436 ss_|              EQ(n, 1)                                                          :S(ssUnOp)
1215 0437                   ss             =  ss(c[1], len)                                   :F(FRETURN)
1216 0438                   i              =  1
1217 0439 ss_|0             i              =  LT(i, n) i + 1                                  :F(RETURN)
1218 0440                   ss             =  ss ' | ' ss(c[i], len - SIZE(ss) - 3)           :S($'ss_|0')F(FRETURN)
1219 0441 *//-------------- -------------- -- ----------------------------------------------- ------------------------
1220 0442 ss_..             ss             =  ss(c[1], len)                                   :F(FRETURN)
1221 0443                   i              =  1
1222 0444 ss_..0            i              =  LT(i, n) i + 1                                  :F(RETURN)
1223 0445                   ss             =  ss ' ' ss(c[i], len - SIZE(ss) - 1)             :S($'ss_..0')F(FRETURN)
1224 0446 *//-------------- -------------- -- ----------------------------------------------- ------------------------
1225 0447 ss_[]             ss             =  ss(c[1], len)                                   :F(FRETURN)
1226 0448                   i              =  1
1227 0449 ss_[]0            i              =  LT(i, n) i + 1                                  :F(RETURN)
1228 0450                   ss             =  ss '[' ss(c[i], len - SIZE(ss) - 2) ']'         :S($'ss_[]0')F(FRETURN)
1229 0451 *//-------------- -------------- -- ----------------------------------------------- ------------------------
1230 0452 ss_()             ss             =  '(' ss(c[1], len - 2) ')'                       :S(RETURN)F(FRETURN)
1231 0453 *//-------------- -------------- -- ----------------------------------------------- ------------------------
1232 0454 ss_snoCall        ss             =  ss(c[1]) '(' ss(c[2], len - SIZE(v) - 2) ')'    :S(RETURN)F(FRETURN)
1233 0455 ssEnd
1234 0456 *//============== ============== == =============================================== ========================
1235 0457                   DEFINE('visit(x,fnc)i')                                           :(visitEnd)
1236 0458 visit             APPLY(fnc, x)                                                     :F(RETURN)
1237 0459                   i              =  0
1238 0460 visit_1           i              =  LT(i, n(x)) i + 1                               :F(RETURN)
1239 0461                   visit(c(x)[i], fnc)                                               :(visit_1)
1240 0462 visitEnd
1241 0463 *//-------------- -------------- -- ----------------------------------------------- ------------------------
1242 0464                   DEFINE('findRefs(x)n,v')
1243 0465                   snoRefs        =                                                  :(findRefsEnd)
1244 0466 findRefs          DIFFER(x)                                                         :F(RETURN)
1245 0467                   IDENT(t(x), 'snoCall')                                            :F(findRefs_1)
1246 0468                   n              =  1
1247 0469 findRefs_0        n              =  LT(n, n(x)) n + 1                               :F(FRETURN)
1248 0470                   visit(c(x)[n], .findRefs)                                         :(findRefs_0)
1249 0471 findRefs_1        (IDENT(t(x), '&') EQ(n(x), 1))                                    :F(findRefs_2)
1250 0472                   v              =  ss(x)                                           :(findRefs_9)
1251 0473 findRefs_2        IDENT(t(x), 'snoId')                                              :F(RETURN)
1252 0474                   v              =  v(x)                                            :(findRefs_9)
1253 0475 findRefs_9        v              POS(0) SPAN('0123456789' &UCASE '_') RPOS(0)       :F(FRETURN)
1254 0476                   snoRefs        =  DIFFER(snoRefs) snoRefs ' ' v                   :S(FRETURN)
1255 0477                   snoRefs        =  IDENT(snoRefs) v                                :(FRETURN)
1256 0478 findRefsEnd
1257 0479 *//-------------- -------------- -- ----------------------------------------------- ------------------------
1258 0480                   DEFINE('refs(p)c,n,s,subj')                                       :(refsEnd)
1259 0481 refs              c              =  c(p)
1260 0482                   n              =  0
1261 0483 refs_0            n              =  LT(n, n(p)) n + 1                               :F(RETURN)
1262 0484                   IDENT(t(c[n]), 'snoStmt')                                         :F(refs_0)
1263 0485                   s              =  s + 1
1264 0486                   IDENT(t(c(c[n])[3]))                                              :F(refs_0)
1265 0487                   IDENT(t(c(c[n])[4]), '=')                                         :F(refs_0)
1266 0488                   IDENT(t(c(c[n])[2]), 'snoId')                                     :S(refs_1)
1267 0489                   IDENT(t(c(c[n])[2]), '$')                                         :S(refs_1)F(refs_0)
1268 0490 refs_1            subj           =  ss(c(c[n])[2])
1269 0491                   snoRefs        =
1270 0492                   visit(c(c[n])[5], .findRefs)
1271 0493                   OUTPUT         =  LPAD(s, 3, 0) ': ' RPAD(subj, 38) ' ' snoRefs   :(refs_0)
1272 0494 refsEnd
1273 0495 *//============== ============== == =============================================== ========================
1274 0496 *//               Main program.
1275 0497 *//               Read a SNOBOL4 program.
1276 0498 *//               Parse the SNOBOL4 program.
1277 0499 *//               Generate a more beautiful SNOBOL4 program.
1278 0500 *//
1279 0501                   doDebug        =  0
1280 0502                   snoSpace       =  SPAN(' ' tab) | epsilon
1281 0503 main00            snoLine        =  INPUT                                           :F(END)
1282 0504 main01            snoSrc         =
1283 0505                   snoLine        POS(0) ANY('*-')                                   :F(main02)
1284 0506                   OUTPUT         =  snoLine                                         :(main00)
1285 0507 main02            snoSrc         =  snoSrc snoLine nl
1286 0508                   snoLine        =  INPUT                                           :F(main05)
1287 0509                   snoLine        POS(0) ANY('.+')                                   :S(main02)
1288 0510                   snoSrc         POS(0) *snoParse *snoSpace RPOS(0)                 :F(mainErr1)
1289 0511                   DIFFER(sno = Pop())                                               :F(mainErr2)
1290 0512                   pp(sno)                                                           :(main01)
1291 0513 main05            snoSrc         POS(0) *snoParse *snoSpace RPOS(0)                 :F(mainErr1)
1292 0514                   DIFFER(sno = Pop())                                               :F(mainErr2)
1293 0515                   pp(sno)                                                           :(END)
1294 0516 mainErr1          OUTPUT         =  'Parse Error'
1295 0517                   OUTPUT         =  snoSrc                                          :(END)
1296 0518 mainErr2          OUTPUT         =  'Internal Error'
1297 0519                   OUTPUT         =  snoSrc                                          :(END)
1298 0520 *//-INCLUDE 'debug.sno'
1299 0521 end
