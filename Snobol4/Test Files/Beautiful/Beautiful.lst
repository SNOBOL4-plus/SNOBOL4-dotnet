0069 0001 *//-----------------------------------------------------------------------------------------------------
0070 0002 *// $Workfile: io.inc $ $Revision: 3 $ $Date: 3/10/05 11:46a $ 
0071 0003 *//-----------------------------------------------------------------------------------------------------
0072 0004 *//
0073 0005 *// Provide SPITBOL input/output semantics within SNOBOL4 programs.
0074 0006 *// Make INPUT() and OUTPUT() functions still accessible.
0075 0007 *// Map INPUT() and OUTPUT() functions to the following user defined functions.
0076 0008 *// The recognition and interpretation of the options is incomplete.
0077 0009 *//
0078 0010 *//----------- -------------------------------------------------------------------- --------------------
0079 0011                IsSnobol4()                                                          :F(io_end)
0080 0012                DEFINE('input_(name,channel,fileName)bch,cmd,maxreclen,opts,options')
0081 0013                DEFINE('output_(name,channel,fileName)bch,cmd,maxreclen,opts,options')
0082 0014                OPSYN('input__', 'INPUT')
0083 0015                OPSYN('output__', 'OUTPUT')
0084 0016                OPSYN('INPUT', 'input_')
0085 0017                OPSYN('OUTPUT', 'output_')
0086 0018                ioFileOptDash  =  (  '-l'
0086 0018 +                                   SPAN(digits) . maxreclen . *assign(.options, *(options maxreclen))
0086 0018 +                                |  '-m' SPAN(digits)
0086 0018 +                                |  '-a' . *assign(.options, *(options 'a'))
0086 0018 +                                |  '-w' . *assign(.options, *(options 'w'))
0086 0018 +                                )
0087 0019                ioFileOptList  =  *ioFileOptDash (SPAN(' ,') *ioFileOptList | epsilon)
0088 0020                ioFileOptPat   =  '[' *ioFileOptList ']'
0089 0021                ioFileOptPat0  =  *ioFileOptPat | epsilon
0090 0022                ioCmdDlmtPat1  =  LEN(1) $ bch BREAK(*bch) . cmd *bch
0091 0023                ioCmdDlmtPat2  =  LEN(1) REM . cmd                                   :(io_end)
0092 0024 input_         io             =  .input__                                           :(io)
0093 0025 output_        io             =  .output__                                          :(io)
0094 0026 io             fileName       POS(0) '!' ioCmdDlmtPat1 ioFileOptPat0 = '|' cmd      :S(io1)
0095 0027                fileName       POS(0) '!' ioCmdDlmtPat2 = '|' cmd                    :S(io1)
0096 0028                fileName       ioFileOptPat =                                        :S(io1)
0097 0029 io1            options        =  IDENT(maxreclen) options 1024
0098 0030                APPLY(io, name, channel, options, fileName)                          :S(RETURN)F(FRETURN)
0099 0031 io_end
0068 0012 -INCLUDE 'io.inc'
0101 0001 *//--------------------------------------------------------------------------------------------------
0102 0002 *// $Workfile: case.inc $ $Revision: 3 $ $Date: 3/10/05 11:42a $ 
0103 0003 *//----------- -------------------------------------------------------------------- -----------------
0104 0004 *//
0105 0005 *// Lower case string: string = lwr(string)
0106 0006 *//
0107 0007                DEFINE('lwr(lwr)')                                                   :(lwr_end)
0108 0008 lwr            lwr            =   REPLACE(lwr, &UCASE, &LCASE)                      :(RETURN)
0109 0009 lwr_end
0110 0010 *//----------- -------------------------------------------------------------------- -----------------
0111 0011 *//
0112 0012 *// Upper case string: string = upr(string)
0113 0013 *//
0114 0014                DEFINE('upr(upr)')                                                   :(upr_end)
0115 0015 upr            upr            =   REPLACE(upr, &LCASE, &UCASE)                      :(RETURN)
0116 0016 upr_end
0117 0017 *//----------- -------------------------------------------------------------------- -----------------
0118 0018 *//
0119 0019 *// Capitalize string: string = cap(string)
0120 0020 *//
0121 0021                DEFINE('cap(cap)')                                                   :(cap_end)
0122 0022 cap            cap            =   REPLACE(SUBSTR(cap, 1, 1), &LCASE, &UCASE)
0122 0022 +                                 REPLACE(SUBSTR(cap, 2), &UCASE, &LCASE)           :S(RETURN)F(error)
0123 0023 cap_end
0124 0024 *//----------- -------------------------------------------------------------------- -----------------
0125 0025 *//
0126 0026 *// Create pattern for case insensitive string match:
0127 0027 *// pattern = icase(string)
0128 0028 *//
0129 0029                DEFINE('icase(str)letter,character')                                 :(icase_end)
0130 0030 icase          IDENT(str)                                                           :S(RETURN)
0131 0031                str            POS(0) ANY(&UCASE &LCASE) . letter =                  :F(icase1)
0132 0032                icase          =   icase (upr(letter) | lwr(letter))                 :(icase)
0133 0033 icase1         str            POS(0) LEN(1) . character =
0134 0034                icase          =   icase character                                   :(icase)
0135 0035 icase_end
0100 0032 -INCLUDE 'case.inc'
0137 0001 *//--------------------------------------------------------------------------
0138 0002 *// $Workfile: assign.inc $ $Revision: 6 $ $Date: 3/25/05 11:29p $ 
0139 0003 *//--------------------------------------------------------------------------
0140 0004 *//               
0141 0005 *// Assignment during pattern matching: The unevaluated expression may fail
0142 0006 *// which causes the assignment not to occur, but the pattern that invoked
0143 0007 *// the assignment will always continue.
0144 0008 *//               
0145 0009 *// pattern . *assign(name, expression)
0146 0010 *//               
0147 0011 *//-------- -------------------------------------------- --------------------
0148 0012             DEFINE('assign(name,expression)')            :(assign_end)
0149 0013 assign      assign   =     .dummy
0150 0014             IDENT(DATATYPE(expression), 'EXPRESSION')    :F(assign1)
0151 0015             $name    =     EVAL(expression)              :(NRETURN)
0152 0016 assign1     $name    =     expression                    :(NRETURN)
0153 0017 assign_end
0136 0036 -INCLUDE 'assign.inc'
0155 0001 *//-----------------------------------------------------------------------------------------------------------------------
0156 0002 *// $Workfile: match.inc $ $Revision: 3 $ $Date: 3/13/05 5:32p $ 
0157 0003 *//-----------------------------------------------------------------------------------------------------------------------
0158 0004 *//
0159 0005 *// Pattern matching during pattern matching:
0160 0006 *// pattern $ variable $ *match(variable, pattern)
0161 0007 *// pattern $ variable $ *notmatch(variable, pattern)
0162 0008 *//
0163 0009 *//----------- --------------------------------------------------------------------- -----------------
0164 0010                DEFINE('match(subject,pattern)')                                      :(match_end)
0165 0011 match          match          =  .dummy
0166 0012                subject        pattern                                                :S(NRETURN)F(FRETURN)
0167 0013 match_end
0168 0014 *//----------- --------------------------------------------------------------------- -----------------
0169 0015                DEFINE('notmatch(subject,pattern)')                                   :(notmatch_end)
0170 0016 notmatch       notmatch       =  .dummy
0171 0017                subject        pattern                                                :S(FRETURN)F(NRETURN)
0172 0018 notmatch_end
0154 0018 -INCLUDE 'match.inc'
